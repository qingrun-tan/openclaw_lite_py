# OpenClaw Lite 环境变量配置模板
# 复制此文件为 .env 并填入真实值

# 必填：API 密钥
OPENCLAW_API_KEY=your_api_key_here

# 可选：API 基础地址（默认 OpenAI 兼容接口）
OPENCLAW_API_BASE=https://api.openai.com/v1

# 可选：模型名称（默认 gpt-4）
OPENCLAW_MODEL=gpt-4

# 可选：服务端口（默认 18789）
OPENCLAW_PORT=18789

# 可选：沙箱目录（默认 ./data/sandbox）
OPENCLAW_SANDBOX=./data/sandbox

# 可选：最大 Token 限制（默认 100000）
OPENCLAW_MAX_TOKENS=100000

# 可选：记忆存储类型（file/redis）
OPENCLAW_MEMORY_TYPE=file

# Redis 配置（当 MEMORY_TYPE=redis 时使用）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
